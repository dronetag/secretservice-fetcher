# Example .secretrc -- copy to .secretrc next to your code and edit.
# Contains NO secrets: only where each config lives in the keyring and where
# it should be materialised. Safe to commit.

# Directory used to materialise files at runtime. Leave it unset: it defaults to
# $XDG_RUNTIME_DIR, which systemd sets for user services and which equals the
# unit's %t -- so the tool and the unit agree without hardcoding anything. Only
# set it for non-systemd use, e.g.  runtime_dir = "/run/user/{uid}"  ({uid} -> uid).
# runtime_dir = "/run/user/{uid}"

[defaults]
# Attributes merged into every config's Secret Service lookup key.
attributes = { app = "dummy" }
# Optional label prefix; the logical name is appended -> "dummy prod.yaml".
label_prefix = "dummy"
mode = "0600"

[[configs]]
name = "prod.yaml"
# Final lookup attributes: app=dummy, kind=config, name=prod.yaml
attributes = { kind = "config" }
develop_path = "./config/prod.yaml"
env = "APP_CONFIG"          # exports APP_CONFIG=<materialised file path>
default = true
# writeback = true          # if the program rewrites the file (e.g. rotates a
                            # refresh token), save the change back to the store

# Add more config files as needed:
# [[configs]]
# name = "staging.yaml"
# attributes = { kind = "config" }
# develop_path = "./config/staging.yaml"

# --- environment variables --------------------------------------------------
# Each [[env]] entry looks a scalar secret up and injects its VALUE as an env
# var for the wrapped program. Store one with `ss-fetcher set-env VAR`,
# or bulk-import a JSON/.env file with `ss-fetcher import-env --from f`.

[[env]]
# keyring item name=PERSONAL_O365_CLIENT_ID  ->  $O365_CLIENT_ID
var = "O365_CLIENT_ID"
name = "PERSONAL_O365_CLIENT_ID"
attributes = { kind = "env" }

[[env]]
# name defaults to var when the keyring name matches the env var name.
var = "O365_CLIENT_SECRET"
attributes = { kind = "env" }
