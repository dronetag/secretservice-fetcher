# Example .secretrc for the "dummy" service.
# No secrets here -- only where each config/secret lives. Safe to commit.

id = "dummy"                    # namespaces the prepare dir + Vault base path
backend = "secret-service"      # or "vault" (see ../../README.md)

# runtime_dir is intentionally NOT set: it defaults to $XDG_RUNTIME_DIR, which
# systemd sets for user services and which equals the unit's %t specifier. That
# keeps the directory the tool writes to (`%t/ss-fetcher/<id>`) in sync with the
# paths the unit references. Only set runtime_dir for non-systemd use, e.g.
#   runtime_dir = "/run/user/{uid}"
# See examples/systemd/README.md ("Runtime directory").

[defaults]
attributes = { app = "dummy" }
label_prefix = "dummy"
mode = "0600"

[[configs]]
name = "prod.yaml"
# Final keyring lookup key: app=dummy, kind=config, name=prod.yaml
attributes = { kind = "config" }
develop_path = "./config/prod.yaml"
env = "APP_CONFIG"          # exports APP_CONFIG=<materialised file path>
default = true

# Individual secrets injected as environment variables (cf. a secrets.json).
# `ss-fetcher set-env O365_CLIENT_ID` stores one; `run`/`prepare` use them.

[[env]]
# keyring name=PERSONAL_O365_CLIENT_ID  ->  $O365_CLIENT_ID  (a rename)
var = "O365_CLIENT_ID"
name = "PERSONAL_O365_CLIENT_ID"
attributes = { kind = "env" }

[[env]]
var = "O365_CLIENT_SECRET"
attributes = { kind = "env" }
